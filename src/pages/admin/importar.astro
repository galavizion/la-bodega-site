---
export const prerender = false;

// Protección básica — solo en dev o con token
const isDev = import.meta.env.DEV;
if (!isDev) {
  return Astro.redirect("/");
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Importar productos desde Excel</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: system-ui, sans-serif;
      background: #0f172a;
      color: #e2e8f0;
      margin: 0;
      min-height: 100vh;
      padding: 40px 20px;
    }
    .wrap { max-width: 860px; margin: 0 auto; }
    h1 { font-size: 24px; margin: 0 0 8px; }
    .sub { opacity: .6; margin: 0 0 32px; font-size: 14px; }

    .card {
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 16px;
      padding: 28px;
      margin-bottom: 24px;
    }
    h2 { font-size: 16px; margin: 0 0 16px; }

    .template-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      border-radius: 10px;
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.12);
      color: inherit;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 20px;
    }
    .template-link:hover { background: rgba(255,255,255,.14); }

    label { display: block; font-size: 13px; opacity: .7; margin-bottom: 6px; }

    input[type="file"] {
      display: block;
      width: 100%;
      padding: 12px;
      border-radius: 10px;
      border: 2px dashed rgba(255,255,255,.2);
      background: rgba(255,255,255,.04);
      color: inherit;
      cursor: pointer;
      font-size: 14px;
      margin-bottom: 16px;
    }
    input[type="file"]:hover { border-color: rgba(255,255,255,.4); }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 20px;
      border-radius: 10px;
      border: none;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity .2s;
    }
    .btn:disabled { opacity: .4; cursor: not-allowed; }
    .btn-primary { background: #4275ff; color: #fff; }
    .btn-primary:hover:not(:disabled) { opacity: .88; }

    #preview {
      margin-top: 20px;
      display: none;
    }
    #preview table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    #preview th, #preview td {
      text-align: left;
      padding: 8px 10px;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    #preview th { opacity: .5; font-weight: 600; text-transform: uppercase; font-size: 11px; }

    #log {
      margin-top: 20px;
      font-size: 13px;
      display: none;
    }
    .log-item { padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,.06); }
    .log-ok { color: #4ade80; }
    .log-err { color: #f87171; }
    .log-skip { color: #facc15; }

    .progress-bar {
      height: 6px;
      background: rgba(255,255,255,.1);
      border-radius: 99px;
      overflow: hidden;
      margin-bottom: 12px;
      display: none;
    }
    .progress-bar__fill {
      height: 100%;
      background: #4275ff;
      width: 0%;
      transition: width .3s;
    }

    .cols-info {
      font-size: 12px;
      opacity: .55;
      line-height: 1.7;
    }
    code { background: rgba(255,255,255,.08); padding: 1px 5px; border-radius: 4px; }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>📥 Importar productos</h1>
    <p class="sub">Carga un archivo Excel (.xlsx / .xls / .csv) para crear o actualizar productos en Sanity.</p>

    <div class="card">
      <h2>Plantilla de columnas</h2>
      <a class="template-link" href="/admin/plantilla-productos.xlsx" download id="downloadTemplate">
        ⬇️ Descargar plantilla Excel
      </a>
      <p class="cols-info">
        <strong>Columnas requeridas:</strong><br/>
        <code>nombre</code> · <code>sku</code> · <code>marca</code> · <code>descripcion</code> ·
        <code>precio</code> · <code>precio_oferta</code> · <code>disponible</code> · <code>categoria</code>
        <br/><br/>
        <strong>Especificaciones de variante (opcional):</strong><br/>
        <code>variante_1</code> · <code>variante_2</code> · <code>variante_3</code><br/>
        Formato: <code>Medida: 1"</code> · <code>Cantidad: 500 pzas</code> · <code>Color: Gris</code>
        <br/><br/>
        <strong>Columnas opcionales:</strong><br/>
        <code>certifications</code> (ul, fm, nom, nsf, ce, iso9001) · <code>whatsappPhone</code> · <code>whatsappMessage</code>
        <br/><br/>
        <strong>Disponible:</strong> <code>si</code> / <code>no</code><br/>
        <strong>Filas con mismo <code>nombre</code></strong> = mismo producto, se agrupan como variantes.
      </p>
    </div>

    <div class="card">
      <h2>Cargar archivo</h2>
      <label for="fileInput">Selecciona tu archivo (.xlsx, .xls, .csv)</label>
      <input type="file" id="fileInput" accept=".xlsx,.xls,.csv" />

      <div id="preview"></div>

      <button class="btn btn-primary" id="importBtn" disabled>
        ⬆️ Importar a Sanity
      </button>

      <div class="progress-bar" id="progressBar">
        <div class="progress-bar__fill" id="progressFill"></div>
      </div>

      <div id="log"></div>
    </div>
  </div>

  <script is:inline src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
  <script is:inline>
    const fileInput = document.getElementById("fileInput");
    const importBtn = document.getElementById("importBtn");
    const previewEl = document.getElementById("preview");
    const logEl = document.getElementById("log");
    const progressBar = document.getElementById("progressBar");
    const progressFill = document.getElementById("progressFill");

    let parsedRows = [];

    // ── Parse file ──────────────────────────────────────
    fileInput.addEventListener("change", async (e) => {
      const file = e.target.files[0];
      if (!file) return;

      const buffer = await file.arrayBuffer();
      const wb = XLSX.read(buffer, { type: "array" });
      const ws = wb.Sheets[wb.SheetNames[0]];
      // range:1 → salta la primera fila (título del template) y usa la segunda como encabezados
      const rows = XLSX.utils.sheet_to_json(ws, { defval: "", range: 1 });

      parsedRows = rows;
      renderPreview(rows.slice(0, 5));
      importBtn.disabled = rows.length === 0;
    });

    function renderPreview(rows) {
      if (!rows.length) return;
      const keys = Object.keys(rows[0]);
      const thead = `<tr>${keys.map(k => `<th>${k}</th>`).join("")}</tr>`;
      const tbody = rows.map(r =>
        `<tr>${keys.map(k => `<td>${r[k]}</td>`).join("")}</tr>`
      ).join("");

      previewEl.style.display = "block";
      previewEl.innerHTML = `
        <p style="font-size:13px;opacity:.6;margin:0 0 10px">${parsedRows.length} filas detectadas — mostrando primeras ${rows.length}</p>
        <div style="overflow-x:auto"><table><thead>${thead}</thead><tbody>${tbody}</tbody></table></div>
      `;
    }

    // ── Import ───────────────────────────────────────────
    importBtn.addEventListener("click", async () => {
      if (!parsedRows.length) return;

      importBtn.disabled = true;
      logEl.style.display = "block";
      logEl.innerHTML = "";
      progressBar.style.display = "block";

      let ok = 0, err = 0, skip = 0;

      for (let i = 0; i < parsedRows.length; i++) {
        const row = parsedRows[i];
        const pct = Math.round(((i + 1) / parsedRows.length) * 100);
        progressFill.style.width = pct + "%";

        try {
          const res = await fetch("/api/import-product/", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(row),
          });
          const data = await res.json();

          if (res.ok) {
            ok++;
            addLog("ok", `✅ ${row.title || row.sku || `Fila ${i+1}`} — ${data.action ?? "creado"}`);
          } else {
            err++;
            addLog("err", `❌ ${row.title || `Fila ${i+1}`} — ${data.error ?? "error"}`);
          }
        } catch (e) {
          err++;
          addLog("err", `❌ Fila ${i+1} — Error de red`);
        }
      }

      addLog("ok", `─── Listo: ${ok} importados · ${skip} omitidos · ${err} errores ───`);
      importBtn.disabled = false;
    });

    function addLog(type, msg) {
      const div = document.createElement("div");
      div.className = `log-item log-${type}`;
      div.textContent = msg;
      logEl.appendChild(div);
      logEl.scrollTop = logEl.scrollHeight;
    }
  </script>
</body>
</html>
