---
import "../styles/global.css";
import Header from "../components/Header.astro";

import { sanityFetch } from "../lib/sanity/client";
import { SITE_SETTINGS_QUERY } from "../lib/sanity/queries";

import {
  buildOrgSchema,
} from "../lib/seo/jsonld";



interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;

  seo?: {
    title?: string;
    description?: string;
    canonical?: string;
    noindex?: boolean;
    ogImage?: {
      asset?: {
        url?: string;
      };
    };
  };

  /** JSON-LD extra por página */
  schema?: Record<string, any> | Array<Record<string, any>>;

  /** Fondo editable desde Sanity */
  background?: {
    type?: "gradient" | "solid" | "image";
    color?: string;
    gradientColors?: string;
    image?: any;
    overlay?: number;
  };
}

const {
  title,
  description,
  canonical,
  ogImage,
  seo,
  schema,
  background,
} = Astro.props as Props;

// ── Fondo dinámico ────────────────────────────────────────
const bgType = background?.type ?? "gradient";

const buildBodyBg = () => {
  if (bgType === "solid" && background?.color) {
    return `background:${background.color};animation:none;`;
  }
  if (bgType === "gradient" && background?.gradientColors) {
    const colors = background.gradientColors
      .split("\n")
      .map((c) => c.trim())
      .filter(Boolean)
      .join(", ");
    return `background:linear-gradient(-75deg,${colors});background-size:450% 450%;`;
  }
  return null; // usa el default de global.css
};
const bodyBgStyle = buildBodyBg();

const settings = await sanityFetch<any>({ query: SITE_SETTINGS_QUERY });
// Base
const siteUrl =
  settings?.siteUrl ||
  "https://www.labodegadelinstalador.net";

// SEO final con prioridad al bloque SEO de Sanity
const metaTitle =
  seo?.title ||
  title ||
  settings?.defaultTitle ||
  settings?.siteName ||
  "La Bodega del Instalador";

const metaDescription =
  seo?.description ||
  description ||
  settings?.defaultDescription ||
  "Materiales y suministros para instaladores profesionales.";

const metaCanonical =
  seo?.canonical ||
  canonical ||
  "https://www.labodegadelinstalador.net/";

const metaImage =
  seo?.ogImage?.asset?.url ||
  ogImage ||
  settings?.defaultOgImage?.asset?.url ||
  `${siteUrl}/og.jpg`;

const robots =
  seo?.noindex ? "noindex,nofollow" : "index,follow";

const tagManagerId = settings?.tagManagerId;
const analyticsId = settings?.analyticsId;
const adsenseClient = settings?.adsenseClient;
const searchConsoleVerification = settings?.searchConsoleVerification;

const gtmHeadScript = tagManagerId
  ? `(function(w,d,s,l,i){
      w[l]=w[l]||[];
      w[l].push({'gtm.start': new Date().getTime(), event:'gtm.js'});
      var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),
          dl=l!='dataLayer'?'&l='+l:'';
      j.async=true;
      j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
      f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer',${JSON.stringify(tagManagerId)});`
  : "";

const gaScript = analyticsId
  ? `window.dataLayer = window.dataLayer || [];
     function gtag(){dataLayer.push(arguments);}
     gtag('js', new Date());
     gtag('config', ${JSON.stringify(analyticsId)});`
  : "";
// Siempre metemos Organization + lo extra de la página
const schemas = [
  buildOrgSchema(siteUrl, settings),
  ...(Array.isArray(schema) ? schema : schema ? [schema] : []),
];
---

<!DOCTYPE html>
<html lang="es">
 <head>

  {tagManagerId && (
    <script is:inline set:html={gtmHeadScript}></script>
  )}

  {analyticsId && (
    <script
      is:inline
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${analyticsId}`}
    ></script>
  )}

  {analyticsId && (
    <script is:inline set:html={gaScript}></script>
  )}

  {searchConsoleVerification && (
    <meta
      name="google-site-verification"
      content={searchConsoleVerification}
    />
  )}

  {adsenseClient && (
    <script
      is:inline
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
      crossorigin="anonymous"
    ></script>
  )}

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>{metaTitle}</title>

  <meta
    name="description"
    content={metaDescription}
  />

  <meta
    name="robots"
    content={robots}
  />

  <link
    rel="canonical"
    href={metaCanonical}
  />

  <!-- Open Graph -->
  <meta property="og:title" content={metaTitle} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={metaCanonical} />
  <meta property="og:image" content={metaImage} />

  <!-- Schema JSON-LD -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(schemas)}
  ></script>

  <script is:inline src="/scripts/cart.js" defer></script>

</head>
<body style={bodyBgStyle ?? undefined}>
{bgType === "image" && background?.image?.asset && (
  <div
    class="page-bg-image"
    style={`--overlay:${(background.overlay ?? 0) / 100}`}
    aria-hidden="true"
  ></div>
)}

  {tagManagerId && (
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${tagManagerId}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
  )}

  <Header />

  <div class="page-wrapper">

    <div class="header-spacer" aria-hidden="true"></div>

    <slot />


      <footer class="site-footer" role="contentinfo">
        <div class="footer__upper">
          <div class="container">
            <div class="footer__grid">

              {/* Columna brand */}
              <div class="footer__brand">
                <a href="/" aria-label="Ir al inicio">
                  {settings?.logoAltUrl ? (
                    <img class="footer__logo" src={settings.logoAltUrl} alt={settings?.siteName ?? "Logo"} width="180" height="48" loading="lazy" />
                  ) : settings?.logoUrl ? (
                    <img class="footer__logo" src={settings.logoUrl} alt={settings?.siteName ?? "Logo"} width="180" height="48" loading="lazy" />
                  ) : (
                    <span class="footer__logo-text">{settings?.siteName ?? "Logo"}</span>
                  )}
                </a>

                {settings?.footerTagline && (
                  <p class="footer__tagline">{settings.footerTagline}</p>
                )}

                {/* Redes sociales */}
                {settings?.social && (
                  <div class="footer__social" aria-label="Redes sociales">
                    {settings.social.facebook && (
                      <a href={settings.social.facebook} aria-label="Facebook" target="_blank" rel="noreferrer noopener">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                      </a>
                    )}
                    {settings.social.instagram && (
                      <a href={settings.social.instagram} aria-label="Instagram" target="_blank" rel="noreferrer noopener">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="18" cy="6" r="1"/></svg>
                      </a>
                    )}
                    {settings.social.linkedin && (
                      <a href={settings.social.linkedin} aria-label="LinkedIn" target="_blank" rel="noreferrer noopener">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4V9h4v2"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                      </a>
                    )}
                    {settings.social.youtube && (
                      <a href={settings.social.youtube} aria-label="YouTube" target="_blank" rel="noreferrer noopener">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
                      </a>
                    )}
                    {settings.social.tiktok && (
                      <a href={settings.social.tiktok} aria-label="TikTok" target="_blank" rel="noreferrer noopener">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
                      </a>
                    )}
                  </div>
                )}

                {/* CTA footer */}
                {(settings?.footerCtaUrl || settings?.organization?.whatsapp) && (
                  <a
                    href={settings?.footerCtaUrl ?? `https://wa.me/${settings?.organization?.whatsapp}`}
                    class="footer__cta-btn"
                  >
                    {settings?.footerCtaLabel ?? "Contáctanos"}
                  </a>
                )}
              </div>

              {/* Columnas de links dinámicas */}
              {(settings?.footerColumns ?? []).map((col: any) => (
                <nav class="footer__col" aria-label={col.title}>
                  <h3 class="footer__col-title">{col.title}</h3>
                  <ul class="footer__links">
                    {(col.links ?? []).map((link: any) => (
                      <li><a href={link.url}>{link.label}</a></li>
                    ))}
                  </ul>
                </nav>
              ))}

              {/* Columna contacto / ubicaciones */}
              {settings?.footerLocations?.length > 0 && (
                <div class="footer__col footer__col--contact">
                  <h3 class="footer__col-title">Contacto</h3>
                  <ul class="footer__locations">
                    {settings.footerLocations.map((loc: any) => (
                      <li class="footer__location">
                        {loc.city && <strong>{loc.city}</strong>}
                        {loc.phone && <a href={`tel:${loc.phone}`}>{loc.phone}</a>}
                        {loc.whatsapp && (
                          <a href={`https://wa.me/${loc.whatsapp}`} target="_blank" rel="noreferrer noopener">WhatsApp</a>
                        )}
                        {loc.email && <a href={`mailto:${loc.email}`}>{loc.email}</a>}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

            </div>
          </div>
        </div>

        <div class="footer__bottom">
          <div class="container">
            <p class="footer__legal">
              {settings?.footerCopyright
                ? settings.footerCopyright
                : `© ${new Date().getFullYear()} ${settings?.siteName ?? ""}. Todos los derechos reservados.`}
            </p>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  /* ── FOOTER ─────────────────────────────────────────── */
  .site-footer {
    background: rgba(10, 10, 20, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: rgba(255,255,255,.85);
    border-top: 1px solid rgba(255,255,255,.08);
    margin-top: 60px;
  }

  .footer__upper { padding: 56px 0 40px; }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(auto-fit, minmax(160px, 1fr));
    gap: 40px;
    align-items: start;
  }

  .footer__logo { max-width: 180px; height: auto; }
  .footer__logo-text { font-size: 20px; font-weight: 800; }

  .footer__tagline {
    margin: 14px 0 18px;
    font-size: 14px;
    line-height: 1.6;
    opacity: .75;
    max-width: 28ch;
  }

  .footer__social {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.12);
    transition: background .2s;
  }
  .footer__social a:hover { background: rgba(255,255,255,.18); }

  .footer__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 18px;
    border-radius: 12px;
    background: var(--thm-primary, #4275ff);
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    transition: opacity .2s;
  }
  .footer__cta-btn:hover { opacity: .88; }

  .footer__col-title {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .06em;
    opacity: .5;
    margin: 0 0 14px;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
  }

  .footer__links a {
    font-size: 14px;
    opacity: .8;
    transition: opacity .2s;
  }
  .footer__links a:hover { opacity: 1; }

  .footer__locations {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 14px;
  }

  .footer__location {
    display: grid;
    gap: 3px;
    font-size: 13px;
  }
  .footer__location strong { font-weight: 700; opacity: .9; }
  .footer__location a { opacity: .7; transition: opacity .2s; }
  .footer__location a:hover { opacity: 1; }

  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,.08);
    padding: 18px 0;
  }

  .footer__legal {
    margin: 0;
    font-size: 13px;
    opacity: .5;
    text-align: center;
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer__grid { grid-template-columns: 1fr; }
  }

  /* ── FONDO DE IMAGEN ────────────────────────────────── */
  .page-bg-image {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-image: var(--page-bg-img);
    background-size: cover;
    background-position: center;
  }
  .page-bg-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,var(--overlay,0));
  }
</style>