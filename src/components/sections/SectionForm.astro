---
type FormField = {
  _key?: string;
  type?: "text" | "email" | "tel" | "textarea" | "select";
  label?: string;
  placeholder?: string;
  required?: boolean;
  options?: string;
};

type Props = {
  title?: string;
  subtitle?: string;
  formType?: "contact" | "quote" | "newsletter";
  fields?: FormField[] | null;
  submitLabel?: string;
  successMessage?: string;
  whatsappFallback?: { enabled?: boolean; phone?: string; label?: string } | null;
  settings?: { sectionId?: string };
};

const {
  title,
  subtitle,
  formType = "contact",
  fields,
  submitLabel = "Enviar mensaje",
  successMessage = "¡Mensaje recibido! Te contactamos pronto.",
  whatsappFallback,
  settings,
} = Astro.props as Props;

const sectionId = settings?.sectionId;
const safeFields: FormField[] = Array.isArray(fields) && fields.length
  ? fields
  : [
      { type: "text",     label: "Nombre",   placeholder: "Tu nombre",           required: true  },
      { type: "email",    label: "Correo",   placeholder: "correo@empresa.com",  required: true  },
      { type: "tel",      label: "Teléfono", placeholder: "55 1234 5678",        required: false },
      { type: "textarea", label: "Mensaje",  placeholder: "¿En qué te podemos ayudar?", required: true },
    ];

const formId = `form-${Math.random().toString(36).slice(2, 7)}`;
const waPhone  = whatsappFallback?.phone  ?? "";
const waLabel  = whatsappFallback?.label  ?? "O escríbenos por WhatsApp";
const waActive = whatsappFallback?.enabled && waPhone;
---

<section id={sectionId} class="section form-section">
  <div class="container">
    <div class="form-wrap">
      <div class="form-copy">
        {title    && <h2 class="form-copy__title">{title}</h2>}
        {subtitle && <p  class="form-copy__sub">{subtitle}</p>}

        {waActive && (
          <a
            class="wa-btn"
            href={`https://wa.me/${waPhone}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {waLabel}
          </a>
        )}
      </div>

      <form
        id={formId}
        class="form-card"
        data-form-type={formType}
        data-success={successMessage}
        novalidate
      >
        {safeFields.map((f, i) => {
          const fieldId = `${formId}-${i}`;
          const name = (f.label ?? `campo${i}`).toLowerCase().replace(/\s+/g, "_");
          const opts = f.type === "select" && f.options
            ? f.options.split("\n").map(o => o.trim()).filter(Boolean)
            : [];

          return (
            <div class="field">
              {f.label && <label for={fieldId}>{f.label}{f.required ? " *" : ""}</label>}

              {f.type === "textarea" ? (
                <textarea
                  id={fieldId}
                  name={name}
                  placeholder={f.placeholder ?? ""}
                  required={f.required}
                  rows={4}
                />
              ) : f.type === "select" ? (
                <select id={fieldId} name={name} required={f.required}>
                  <option value="">{f.placeholder ?? "Selecciona una opción"}</option>
                  {opts.map(o => <option value={o}>{o}</option>)}
                </select>
              ) : (
                <input
                  id={fieldId}
                  type={f.type ?? "text"}
                  name={name}
                  placeholder={f.placeholder ?? ""}
                  required={f.required}
                />
              )}
            </div>
          );
        })}

        <div id={`${formId}-status`} class="form-status" aria-live="polite"></div>

        <button type="submit" class="form-btn">
          <span class="form-btn__label">{submitLabel}</span>
          <span class="form-btn__spinner" aria-hidden="true"></span>
        </button>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll("form[data-form-type]").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const f = e.target;
      const status = document.getElementById(f.id + "-status");
      const btn = f.querySelector(".form-btn");
      const label = btn.querySelector(".form-btn__label");
      const spinner = btn.querySelector(".form-btn__spinner");

      btn.disabled = true;
      label.style.opacity = "0";
      spinner.style.display = "block";
      status.textContent = "";
      status.className = "form-status";

      const data = Object.fromEntries(new FormData(f));

      try {
        const res = await fetch("/api/form-submit", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            formType: f.dataset.formType,
            page: window.location.pathname,
            ...data,
          }),
        });

        if (res.ok) {
          status.textContent = f.dataset.success;
          status.className = "form-status form-status--ok";
          f.reset();
        } else {
          const d = await res.json().catch(() => ({}));
          status.textContent = d.error ?? "Ocurrió un error. Intenta de nuevo.";
          status.className = "form-status form-status--err";
        }
      } catch {
        status.textContent = "Error de conexión. Intenta de nuevo.";
        status.className = "form-status form-status--err";
      }

      btn.disabled = false;
      label.style.opacity = "1";
      spinner.style.display = "none";
    });
  });
</script>

<style>
  .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

  .form-wrap {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 64px;
    align-items: start;
  }
  @media (max-width: 720px) {
    .form-wrap { grid-template-columns: 1fr; gap: 32px; }
  }

  .form-copy__title { font-size: clamp(1.5rem, 3vw, 2.2rem); margin: 0 0 16px; line-height: 1.2; }
  .form-copy__sub   { opacity: .65; line-height: 1.7; margin: 0 0 32px; }

  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-radius: 12px;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: .95rem;
    transition: opacity .2s;
  }
  .wa-btn:hover { opacity: .88; }

  /* Form card */
  .form-card {
    background: var(--form-bg, rgba(0,0,0,.03));
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 18px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .field { display: flex; flex-direction: column; gap: 6px; }
  .field label { font-size: 13px; font-weight: 600; opacity: .75; }

  .field input,
  .field select,
  .field textarea {
    padding: 11px 14px;
    border-radius: 10px;
    border: 1px solid rgba(0,0,0,.15);
    background: #fff;
    font-size: 14px;
    font-family: inherit;
    color: inherit;
    transition: border-color .2s, box-shadow .2s;
    resize: vertical;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-accent, #ef4444);
    box-shadow: 0 0 0 3px rgba(239,68,68,.12);
  }

  .form-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 13px 24px;
    border-radius: 12px;
    border: none;
    background: var(--color-accent, #ef4444);
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity .2s;
    min-height: 48px;
  }
  .form-btn:hover:not(:disabled) { opacity: .88; }
  .form-btn:disabled { opacity: .5; cursor: not-allowed; }

  .form-btn__spinner {
    display: none;
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin .7s linear infinite;
    position: absolute;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .form-status {
    font-size: 14px;
    padding: 10px 14px;
    border-radius: 8px;
    display: none;
  }
  .form-status:not(:empty)       { display: block; }
  .form-status--ok  { background: #dcfce7; color: #166534; }
  .form-status--err { background: #fee2e2; color: #991b1b; }
</style>
