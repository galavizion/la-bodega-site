---
import { urlFor } from "../../lib/sanity/image";

type CardItem = {
  _key?: string;
  badge?: string;
  image?: any;
  title?: string;
  description?: string;
  linkLabel?: string;
  linkUrl?: string;
};

type Props = {
  title?: string;
  subtitle?: string;
  columns?: number;
  cardStyle?: "shadow" | "outline" | "filled" | "minimal";
  items?: CardItem[] | null;
  settings?: { sectionId?: string };
};

const {
  title,
  subtitle,
  columns = 3,
  cardStyle = "shadow",
  items,
  settings,
} = Astro.props as Props;

const sectionId = settings?.sectionId;
const safeItems = Array.isArray(items) ? items.filter(Boolean) : [];
const cols = [2, 3, 4].includes(columns) ? columns : 3;
---

<section id={sectionId} class={`section cards cards--${cardStyle}`}>
  <div class="container">
    {(title || subtitle) && (
      <header class="cards__header">
        {title    && <h2 class="cards__title">{title}</h2>}
        {subtitle && <p  class="cards__subtitle">{subtitle}</p>}
      </header>
    )}

    <div class={`cards__grid cards__grid--${cols}`}>
      {safeItems.map((item) => {
        const imgUrl = item.image
          ? urlFor(item.image).width(600).height(400).quality(80).auto("format").url()
          : null;

        return (
          <article class="card">
            {imgUrl && (
              <div class="card__img-wrap">
                <img src={imgUrl} alt={item.title ?? ""} loading="lazy" width="600" height="400" />
              </div>
            )}
            <div class="card__body">
              {item.badge && <span class="card__badge">{item.badge}</span>}
              {item.title && <h3 class="card__title">{item.title}</h3>}
              {item.description && <p class="card__desc">{item.description}</p>}
              {item.linkUrl && item.linkLabel && (
                <a class="card__link" href={item.linkUrl}>{item.linkLabel} →</a>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

  .cards__header { text-align: center; margin-bottom: 48px; }
  .cards__title  { font-size: clamp(1.5rem, 3vw, 2.2rem); margin: 0 0 12px; }
  .cards__subtitle { opacity: .65; font-size: 1.05rem; max-width: 60ch; margin: 0 auto; line-height: 1.6; }

  .cards__grid {
    display: grid;
    gap: 24px;
  }
  .cards__grid--2 { grid-template-columns: repeat(auto-fill, minmax(min(100%, 420px), 1fr)); }
  .cards__grid--3 { grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr)); }
  .cards__grid--4 { grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr)); }

  /* Base card */
  .card {
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform .2s;
  }
  .card:hover { transform: translateY(-3px); }

  /* Estilos */
  .cards--shadow .card  { background: #fff; box-shadow: 0 4px 24px rgba(0,0,0,.08); }
  .cards--outline .card { background: #fff; border: 1px solid rgba(0,0,0,.12); }
  .cards--filled .card  { background: var(--color-accent, #1e293b); color: #fff; }
  .cards--minimal .card { background: transparent; border-bottom: 1px solid rgba(0,0,0,.1); border-radius: 0; }

  .card__img-wrap { aspect-ratio: 3/2; overflow: hidden; }
  .card__img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .3s; }
  .card:hover .card__img-wrap img { transform: scale(1.04); }

  .card__body  { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .cards--minimal .card__body { padding: 16px 0; }

  .card__badge {
    display: inline-block;
    background: var(--color-accent, #ef4444);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: .04em;
    width: fit-content;
  }
  .card__title { font-size: 1.05rem; font-weight: 700; margin: 0; line-height: 1.3; }
  .card__desc  { font-size: .9rem; line-height: 1.6; opacity: .7; margin: 0; flex: 1; }
  .card__link  {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: .88rem;
    font-weight: 600;
    color: var(--color-accent, #ef4444);
    text-decoration: none;
    margin-top: auto;
  }
  .card__link:hover { text-decoration: underline; }

  .cards--filled .card__badge { background: rgba(255,255,255,.2); }
  .cards--filled .card__title { color: #fff; }
  .cards--filled .card__desc  { opacity: .75; color: #fff; }
  .cards--filled .card__link  { color: #fff; }
</style>
