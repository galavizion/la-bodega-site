---
import { urlFor } from "../../lib/sanity/image";

type CardItem = {
  _key?: string;
  badge?: string;
  image?: any;
  title?: string;
  description?: string;
  linkLabel?: string;
  linkUrl?: string;
};

type Props = {
  title?: string;
  subtitle?: string;
  columns?: number;
  cardStyle?: "shadow" | "outline" | "filled" | "minimal";
  bgColor?: string;
  items?: CardItem[] | null;
  settings?: { sectionId?: string };
};

const {
  title,
  subtitle,
  columns = 3,
  cardStyle = "shadow",
  bgColor,
  items,
  settings,
} = Astro.props as Props;

const sectionId = settings?.sectionId;
const safeItems = Array.isArray(items) ? items.filter(Boolean) : [];
const cols = [2, 3, 4].includes(columns) ? columns : 3;

const hasBg = bgColor && bgColor !== "none";
const bgStyle = hasBg ? `background-color:${bgColor};` : undefined;

// Si el fondo es oscuro, el texto heredado puede ser ilegible → forzar color claro
const darkBgs = ["#1e293b", "#0f172a", "#7f1d1d", "#ef4444"];
const forceDark = hasBg && !darkBgs.includes(bgColor!) ? "cards--light-bg" : "";
const forceLight = hasBg && darkBgs.includes(bgColor!) ? "cards--dark-bg" : "";
---

<section id={sectionId} class={`section cards cards--${cardStyle} ${forceDark} ${forceLight}`} style={bgStyle}>
  <div class="container">
    {(title || subtitle) && (
      <header class="cards__header">
        {title    && <h2 class="cards__title">{title}</h2>}
        {subtitle && <p  class="cards__subtitle">{subtitle}</p>}
      </header>
    )}

    <div class={`cards__grid cards__grid--${cols}`}>
      {safeItems.map((item) => {
        const imgUrl = item.image
          ? urlFor(item.image).width(800).quality(85).auto("format").url()
          : null;

        return (
          <article class="card">
            {imgUrl && (
              <div class="card__img-wrap">
                <img src={imgUrl} alt={item.title ?? ""} loading="lazy" />
              </div>
            )}
            <div class="card__body">
              {item.badge && <span class="card__badge">{item.badge}</span>}
              {item.title && <h3 class="card__title">{item.title}</h3>}
              {item.description && <p class="card__desc">{item.description}</p>}
              {item.linkUrl && item.linkLabel && (
                <a class="card__link" href={item.linkUrl}>{item.linkLabel} →</a>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .cards { width: 100%; }

  /* Texto según luminosidad del fondo */
  .cards--dark-bg  { color: #fff; }
  .cards--dark-bg  .cards__subtitle { opacity: .75; }
  .cards--dark-bg  .card__desc      { opacity: .72; }
  .cards--light-bg { color: #111; }
  .cards--light-bg .cards__subtitle { opacity: .65; }

  .cards__header { text-align: left; margin-bottom: 36px; }
  .cards__title  { font-size: clamp(1.5rem, 3vw, 2.2rem); margin: 0 0 10px; }
  .cards__subtitle { opacity: .65; font-size: 1.05rem; line-height: 1.6; margin: 0; }

  .cards__grid {
    display: grid;
    gap: 28px;
  }
  .cards__grid--2 { grid-template-columns: repeat(auto-fill, minmax(min(100%, 420px), 1fr)); }
  .cards__grid--3 { grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr)); }
  .cards__grid--4 { grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr)); }

  /* Base card — sin fondo, sin borde, sin border-radius */
  .card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Quitar cualquier estilo visual por variante */
  .cards--shadow .card,
  .cards--outline .card,
  .cards--filled .card,
  .cards--minimal .card {
    background: transparent;
    box-shadow: none;
    border: none;
    border-radius: 0;
    color: inherit;
  }

  /* Imagen: ancho completo, alto natural, sin crop, sin zoom */
  .card__img-wrap {
    width: 100%;
    overflow: visible;
  }
  .card__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Texto alineado a la izquierda, sin padding lateral */
  .card__body {
    padding: 14px 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 100%;
  }

  .card__badge {
    display: inline-block;
    background: var(--color-accent, #ef4444);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: .04em;
    width: fit-content;
  }
  .card__title { font-size: 1rem; font-weight: 700; margin: 0; line-height: 1.3; }
  .card__desc  { font-size: .875rem; line-height: 1.6; opacity: .7; margin: 0; }
  .card__link  {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: .85rem;
    font-weight: 600;
    color: var(--color-accent, #ef4444);
    text-decoration: none;
    margin-top: 4px;
  }
  .card__link:hover { text-decoration: underline; }
</style>
