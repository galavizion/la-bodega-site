---
import { sanityClient } from "../lib/sanity";
import { resolveHref } from "../lib/nav";
import { SITE_SETTINGS_QUERY } from "../lib/sanity/queries";
import type { NavItem } from "../lib/types";

const settings = await sanityClient.fetch(SITE_SETTINGS_QUERY);
const nav: NavItem[] = settings?.navigation ?? [];
const social = settings?.social ?? {};
const topBar = settings?.topBar;
---

{topBar?.enabled && (
  <div
    class="top-bar"
    style={topBar.bgColor ? `background:${topBar.bgColor}` : undefined}
  >
    <div class="container top-bar__inner">
      {topBar.text && <span>{topBar.text}</span>}
      {topBar.linkUrl && topBar.linkLabel && (
        <a href={topBar.linkUrl}>{topBar.linkLabel}</a>
      )}
    </div>
  </div>
)}

<header class="site-header" data-header>
  <nav class="main-nav container">
    <a class="logo" href="/" aria-label="Ir al inicio">
      {settings?.logoUrl ? (
        <img src={settings.logoUrl} alt={settings?.siteName ?? "Logo"} width="180" height="40" loading="eager" />
      ) : (
        <span class="logo-text">{settings?.siteName ?? "Logo"}</span>
      )}
    </a>

    <ul class="menu" id="mainMenu" data-menu>
      {nav.map((item: NavItem) => {
        const hasChildren = !!item.children?.length;
        return (
          <li class={hasChildren ? "has-submenu" : undefined}>
            {hasChildren ? (
              <>
                <button class="submenu-toggle" type="button" aria-expanded="false" data-submenu-toggle>
                  {item.label}
                  <span class="chev" aria-hidden="true">▾</span>
                </button>
                <ul class="submenu" data-submenu>
                  {item.children!.map((child: NavItem) => (
                    <li><a href={resolveHref(child)}>{child.label}</a></li>
                  ))}
                </ul>
              </>
            ) : (
              <a href={resolveHref(item)}>{item.label}</a>
            )}
          </li>
        );
      })}
    </ul>

    <div class="nav-actions">
      {settings?.headerSocial && (
        <div class="nav-social" aria-label="Redes sociales">
          {social.facebook && (
            <a href={social.facebook} aria-label="Facebook" target="_blank" rel="noreferrer noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          )}
          {social.instagram && (
            <a href={social.instagram} aria-label="Instagram" target="_blank" rel="noreferrer noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="18" cy="6" r="1"/></svg>
            </a>
          )}
          {social.linkedin && (
            <a href={social.linkedin} aria-label="LinkedIn" target="_blank" rel="noreferrer noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4V9h4v2"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          )}
          {social.tiktok && (
            <a href={social.tiktok} aria-label="TikTok" target="_blank" rel="noreferrer noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
            </a>
          )}
        </div>
      )}

      {settings?.cta?.url && (
        <a class="nav-cta" href={settings.cta.url}>
          {settings.cta.label ?? "Contáctanos"}
        </a>
      )}

      <a class="nav-cart" href="/carrito/" aria-label="Ver carrito">
        <span class="nav-cart__icon" aria-hidden="true">🛒</span>
        <span class="nav-cart__badge" data-cart-badge hidden>0</span>
      </a>

      <button
        class="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mainMenu"
        data-menu-toggle
      >
        ☰
        <span class="sr-only">Abrir menú</span>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-header]");
    if (!header) return;

    const setHeaderH = () => {
      document.documentElement.style.setProperty("--header-h", `${header.offsetHeight}px`);
    };

    setHeaderH();
    window.addEventListener("resize", setHeaderH);

    const mo = new MutationObserver(setHeaderH);
    mo.observe(header, { attributes: true, childList: true, subtree: true });

    // --- menú móvil / dropdowns ---
    const toggle = header.querySelector("[data-menu-toggle]");
    const menu = header.querySelector("[data-menu]");
    if (!toggle || !menu) return;

    const submenuToggles = header.querySelectorAll("[data-submenu-toggle]");

    const closeDropdowns = () => {
      submenuToggles.forEach((b) => b.setAttribute("aria-expanded", "false"));
    };

    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      menu.classList.remove("is-open");
      document.documentElement.classList.remove("menu-open");
      closeDropdowns();
      setSpacer();
    };

    const openMenu = () => {
      toggle.setAttribute("aria-expanded", "true");
      menu.classList.add("is-open");
      document.documentElement.classList.add("menu-open");
      setSpacer();
    };

    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      expanded ? closeMenu() : openMenu();
    });

    submenuToggles.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const expanded = btn.getAttribute("aria-expanded") === "true";
        closeDropdowns();
        btn.setAttribute("aria-expanded", expanded ? "false" : "true");
        setSpacer();
      });
    });

    header.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => closeMenu());
    });

    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });

    document.addEventListener("click", (e) => {
      const target = e.target;
      if (!(target instanceof Node)) return;
      if (!header.contains(target)) {
        closeDropdowns();
        if (toggle.getAttribute("aria-expanded") === "true") closeMenu();
      }
    });

    window.matchMedia("(min-width: 901px)").addEventListener("change", () => {
      closeMenu();
    });
  })();
</script>

{/* ✅ Badge carrito */}
<script is:inline>
  (() => {
    const badge = document.querySelector("[data-cart-badge]");
    if (!badge) return;

    const KEY = "ranking_cart_v1";

    const getCount = () => {
      try {
        const items = JSON.parse(localStorage.getItem(KEY) || "[]");
        return Array.isArray(items) ? items.length : 0;
      } catch {
        return 0;
      }
    };

    const render = (count) => {
      if (!count) {
        badge.hidden = true;
        badge.textContent = "0";
      } else {
        badge.hidden = false;
        badge.textContent = String(count);
      }
    };

    // init
    render(getCount());

    // live updates desde cart.js (detail.count)
    window.addEventListener("cart:updated", (e) => {
      const c = e?.detail?.count;
      render(typeof c === "number" ? c : getCount());
    });

    // sync entre pestañas
    window.addEventListener("storage", (e) => {
      if (e.key === KEY) render(getCount());
    });
  })();
</script>

<style>
  /* Top bar */
  .top-bar {
    background: var(--thm-primary, #4275ff);
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    padding: 8px 0;
    text-align: center;
  }
  .top-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .top-bar a {
    text-decoration: underline;
    text-underline-offset: 2px;
    opacity: .9;
  }

  /* Nav social */
  .nav-social {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .nav-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    transition: background .2s;
  }
  .nav-social a:hover { background: rgba(255,255,255,.1); }

  /* CTA nav */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 9px 16px;
    border-radius: 10px;
    background: var(--thm-primary, #4275ff);
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity .2s;
  }
  .nav-cta:hover { opacity: .88; }

  /* Logo text fallback */
  .logo-text { font-weight: 800; font-size: 18px; }

  .nav-actions{
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .nav-cart{
    position: relative;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width: 42px;
    height: 42px;
    border-radius: 14px;
    text-decoration:none;
    color: inherit;
  }

  .nav-cart:hover{
    background: rgba(255,255,255,.08);
  }

  .nav-cart__badge{
    position:absolute;
    top: 6px;
    right: 6px;
    min-width: 18px;
    height: 18px;
    padding: 0 6px;
    border-radius: 999px;
    background: #111827;
    color: #fff;
    font-size: 11px;
    font-weight: 900;
    display:flex;
    align-items:center;
    justify-content:center;
    line-height: 1;
  }
</style>